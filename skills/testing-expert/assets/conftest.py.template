@pytest.fixture
def assert_contains():
    """Helper to check if substring is in string."""
    def _assert_contains(haystack: str, needle: str) -> None:
        assert needle in haystack, f"'{needle}' not found in '{haystack}'"
    return _assert_contains


@pytest.fixture
def assert_valid_json():
    """Helper to validate JSON structure."""
    import json
    def _assert_valid_json(data: Any, required_keys: list = None) -> None:
        if isinstance(data, str):
            data = json.loads(data)
        if required_keys:
            for key in required_keys:
                assert key in data, f"Missing required key: {key}"
        return data
    return _assert_valid_json


