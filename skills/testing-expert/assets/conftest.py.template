# ============================================================================
# Skip Conditions
# ============================================================================

# Skip tests based on environment
skip_in_ci = pytest.mark.skipif(
    os.getenv("CI") == "true",
    reason="Skipped in CI environment"
)

skip_on_windows = pytest.mark.skipif(
    os.name == "nt",
    reason="Skipped on Windows"
)

skip_on_linux = pytest.mark.skipif(
    os.name == "posix",
    reason="Skipped on Linux"
)

# Skip if optional dependency not installed
def skip_if_missing(module_name: str):
    """Skip test if module is not installed."""
    try:
        __import__(module_name)
        return pytest.mark.skipif(False, reason="")
    except ImportError:
        return pytest.mark.skipif(
            True,
            reason=f"Missing dependency: {module_name}"
        )